# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/diemhoavon"

# ============================================================
# NEXTAUTH
# ============================================================
# Generate: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# URL của app khi deploy (không có dấu / cuối)
NEXTAUTH_URL="https://yourdomain.com"

# ============================================================
# GOOGLE OAUTH (tùy chọn — bỏ qua nếu không dùng Google login)
# ============================================================
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ============================================================
# SMTP — Gửi email báo cáo (tùy chọn)
# ============================================================
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@yourdomain.com"
